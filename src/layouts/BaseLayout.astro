---
import "@/styles/tailwind.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import SeoMeta from "@/components/SeoMeta.astro";
import AccessibilityToolbar from "@/components/AccessibilityToolbar.astro";
import CookieBanner from "@/components/CookieBanner.astro";
import { languageList } from "@/i18n/ui";

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
  schema?: string;
}

const defaultSchema = JSON.stringify({
  "@context": "http://schema.org",
  "@type": "WebSite",
  url: "https://www.rustilian.com",
  name: "Rustilian",
  description:
    "Rustilian — IT solutions, open source projects and tools built with Rust.",
  potentialAction: {
    "@type": "SearchAction",
    target: "https://www.rustilian.com/search?q={search_term_string}",
    "query-input": "required name=search_term_string",
  },
});

const {
  title = "Rustilian — IT Solutions & Open Source Projects",
  description = "Rustilian builds open source tools and IT solutions. Explore ORCA Options, ORCA Stocks, QLTSYS and more.",
  keywords = "Rustilian, open source, Rust, IT solutions, ORCA, QLTSYS, software development",
  ogImage = "https://www.rustilian.com/image.png",
  canonical,
  noindex = false,
  schema = defaultSchema,
} = Astro.props;

const currentLang = Astro.currentLocale || "en";
---

<!doctype html>
<html lang={currentLang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO Meta Tags e URLs canônicas -->
    <SeoMeta
      title={title}
      description={description}
      canonical={canonical}
      noindex={noindex}
    />

    <!-- Título SEO dinâmico -->
    <title>{title}</title>

    <!-- Meta Tags SEO dinâmicos -->
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />

    <!-- Open Graph dinâmico -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter Cards dinâmico -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon e ícones -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#b91c1c" />

    <!-- Schema Markup JSON-LD -->
    <script type="application/ld+json" set:html={schema} />
  </head>
  <body
    class="bg-white dark:bg-[#200800] text-gray-900 dark:text-gray-100 min-h-screen relative"
  >
    <Header />
    <main class="min-h-[calc(100vh-8rem)] relative z-10">
      <!-- Conteúdo -->
      <slot />
    </main>
    <Footer />
    <AccessibilityToolbar />
    <CookieBanner />
  </body>
</html>

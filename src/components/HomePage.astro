---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { languageList } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";

const currentLang = Astro.currentLocale || "en";
const translateLabels = useTranslations(
    currentLang as keyof typeof languageList,
);

const projects = [
    {
        key: "orca_options",
        name: translateLabels("home.orca_options.name"),
        description: translateLabels("home.orca_options.description"),
        status: translateLabels("home.orca_options.status"),
        inDevelopment: false,
        gradient: "from-red-700 to-orange-500",
        border: "border-red-700/30",
        icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
    },
    {
        key: "orca_stocks",
        name: translateLabels("home.orca_stocks.name"),
        description: translateLabels("home.orca_stocks.description"),
        status: translateLabels("home.orca_stocks.status"),
        inDevelopment: true,
        gradient: "from-orange-600 to-amber-400",
        border: "border-orange-600/30",
        icon: "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6",
    },
    {
        key: "qltsys",
        name: translateLabels("home.qltsys.name"),
        description: translateLabels("home.qltsys.description"),
        status: translateLabels("home.qltsys.status"),
        inDevelopment: false,
        gradient: "from-emerald-500 to-teal-500",
        border: "border-emerald-500/30",
        icon: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10",
    },
] as const;
---

<BaseLayout title={translateLabels("home.title")}>
    <!-- Hero Section -->
    <div class="relative pt-24 pb-16 overflow-hidden">
        <div class="absolute inset-0 bg-white dark:bg-[#200800]"></div>
        <div
            class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-red-900/5 via-white to-white dark:from-red-900/20 dark:via-[#200800] dark:to-[#200800]"
        >
        </div>

        <div class="container mx-auto text-center px-4 relative z-10">
            <div class="max-w-4xl mx-auto">
                <!-- Logo -->
                <div class="flex justify-center mb-8 animate-fade-in">
                    <img
                        src="/assets/Rustilian-Logo.svg"
                        alt="Rustilian"
                        class="h-78 w-auto transition-opacity duration-300 group-hover:opacity-80"
                        onerror="this.style.display='none'"
                    />
                </div>

                <!-- <h1
                    class="text-5xl md:text-7xl font-bold mb-6 tracking-tight animate-fade-in [text-shadow:_0_4px_30px_rgba(0,0,0,0.5)]"
                >
                    <span
                        class="bg-clip-text text-transparent bg-gradient-to-r from-red-700 via-orange-600 to-orange-400"
                    >
                        Rustilian
                    </span>
                </h1> -->

                <p
                    class="text-lg md:text-xl font-semibold mb-4 text-orange-500 tracking-wide uppercase"
                >
                    {translateLabels("home.hero.tagline")}
                </p>

                <p
                    class="text-xl md:text-2xl mb-10 text-gray-600 dark:text-gray-300 max-w-2xl mx-auto leading-relaxed"
                >
                    {translateLabels("home.hero.description")}
                </p>

                <div class="animate-fade-in delay-200">
                    <a
                        href="#projects"
                        class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-white bg-orange-700 hover:bg-orange-600 rounded-xl transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-orange-700/50"
                    >
                        {translateLabels("home.hero.cta")}
                        <svg
                            class="w-5 h-5 ml-2"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 9l-7 7-7-7"></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Projects Section -->
    <section
        id="projects"
        class="bg-white dark:bg-[#200800] py-20 border-t border-gray-200 dark:border-white/5"
    >
        <div class="container mx-auto px-4">
            <div class="text-center mb-16">
                <h2
                    class="text-3xl md:text-4xl font-bold mb-4 text-gray-900 dark:text-white"
                >
                    <span
                        class="bg-clip-text text-transparent bg-gradient-to-r from-red-700 to-orange-500"
                    >
                        {translateLabels("home.projects.title")}
                    </span>
                </h2>
                <p
                    class="text-gray-500 dark:text-gray-400 max-w-xl mx-auto text-lg"
                >
                    {translateLabels("home.projects.subtitle")}
                </p>
            </div>

            <div
                class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto"
            >
                {
                    projects.map((project) => (
                        <div
                            class={`relative flex flex-col rounded-2xl border bg-gray-50 dark:bg-white/3 ${project.border} p-8 transition-all duration-300 hover:scale-[1.02] hover:shadow-xl hover:shadow-orange-700/10 overflow-hidden`}
                        >
                            {/* Gradient accent bar */}
                            <div
                                class={`absolute top-0 left-0 right-0 h-1 bg-gradient-to-r ${project.gradient}`}
                            />

                            {/* Icon */}
                            <div
                                class={`inline-flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br ${project.gradient} bg-opacity-10 mb-6`}
                            >
                                <svg
                                    class="w-6 h-6 text-white"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d={project.icon}
                                    />
                                </svg>
                            </div>

                            {/* Header row: name + badge */}
                            <div class="flex items-start justify-between gap-3 mb-4">
                                <h3 class="text-xl font-bold text-gray-900 dark:text-white leading-tight">
                                    {project.name}
                                </h3>
                                {project.inDevelopment ? (
                                    <span class="shrink-0 inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-amber-500/15 text-amber-400 border border-amber-500/30">
                                        <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse" />
                                        {project.status}
                                    </span>
                                ) : (
                                    <span class="shrink-0 inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-emerald-500/15 text-emerald-400 border border-emerald-500/30">
                                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400" />
                                        {project.status}
                                    </span>
                                )}
                            </div>

                            {/* Description */}
                            <p class="text-gray-600 dark:text-gray-400 leading-relaxed text-sm flex-grow">
                                {project.description}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>
</BaseLayout>

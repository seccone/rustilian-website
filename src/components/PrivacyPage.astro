---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { languageList } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";

const currentLang = Astro.currentLocale || "en";
const t = useTranslations(currentLang as keyof typeof languageList);
---

<BaseLayout title={t("privacy.title")}>
    <div class="relative pt-24 pb-16 bg-white dark:bg-[#200800] min-h-screen">
        <div class="container mx-auto px-4 max-w-3xl">
            <h1
                class="text-3xl md:text-4xl font-bold mb-2 text-gray-900 dark:text-white"
            >
                {t("privacy.title")}
            </h1>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-10">
                {t("privacy.updated")}
            </p>

            <div
                class="prose dark:prose-invert max-w-none text-gray-700 dark:text-gray-300 space-y-8"
            >
                <section>
                    <h2
                        class="text-xl font-semibold text-gray-900 dark:text-white mb-3"
                    >
                        {t("privacy.s1.title")}
                    </h2>
                    <p>{t("privacy.s1.body")}</p>
                </section>

                <section>
                    <h2
                        class="text-xl font-semibold text-gray-900 dark:text-white mb-3"
                    >
                        {t("privacy.s2.title")}
                    </h2>
                    <p>{t("privacy.s2.body")}</p>
                    <p class="mt-3">{t("privacy.s2.list")}</p>
                    <ul class="list-disc pl-6 mt-2 space-y-1">
                        <li>
                            <strong>{t("privacy.s2.item1.label")}</strong> — {
                                t("privacy.s2.item1.body")
                            }
                        </li>
                        <li>
                            <strong>{t("privacy.s2.item2.label")}</strong> — {
                                t("privacy.s2.item2.body")
                            }
                        </li>
                    </ul>
                </section>

                <section>
                    <h2
                        class="text-xl font-semibold text-gray-900 dark:text-white mb-3"
                    >
                        {t("privacy.s3.title")}
                    </h2>
                    <p>{t("privacy.s3.body1")}</p>
                    <p class="mt-3">{t("privacy.s3.body2")}</p>
                </section>

                <section>
                    <h2
                        class="text-xl font-semibold text-gray-900 dark:text-white mb-3"
                    >
                        {t("privacy.s4.title")}
                    </h2>
                    <p>{t("privacy.s4.body")}</p>
                </section>

                <section>
                    <h2
                        class="text-xl font-semibold text-gray-900 dark:text-white mb-3"
                    >
                        {t("privacy.s5.title")}
                    </h2>
                    <p>{t("privacy.s5.body")}</p>
                </section>

                <section>
                    <h2
                        class="text-xl font-semibold text-gray-900 dark:text-white mb-3"
                    >
                        {t("privacy.s6.title")}
                    </h2>
                    <p>{t("privacy.s6.body")}</p>
                </section>

                <section>
                    <h2
                        class="text-xl font-semibold text-gray-900 dark:text-white mb-3"
                    >
                        {t("privacy.s7.title")}
                    </h2>
                    <p>
                        {t("privacy.s7.body")}
                        <a
                            href="mailto:contact@rustilian.com"
                            class="text-orange-500 hover:underline"
                            >contact@rustilian.com</a
                        >
                    </p>
                </section>
            </div>
        </div>
    </div>
</BaseLayout>
